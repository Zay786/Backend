{
  "version": 2,
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/ml/generate",
      "dest": "/api/ml.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/[...route].js"
    }
  ]
}
